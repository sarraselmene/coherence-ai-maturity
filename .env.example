# Copier en `.env` et renseigner. NE JAMAIS committer `.env`.

# --- Neo4j (Graph-RAG, étape 5) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-please
NEO4J_DATABASE=neo4j

# --- LLM (Graph-RAG + rapport, étapes 5 & 6) ---
# Modèle par défaut recommandé pour la génération de rapport.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Embeddings pour LlamaIndex (étape 5) ---
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=
